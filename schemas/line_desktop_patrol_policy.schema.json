{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://member.app/schemas/line_desktop_patrol_policy.schema.json",
  "title": "line_desktop_patrol_policy",
  "type": "object",
  "required": [
    "enabled",
    "dry_run_default",
    "allowed_targets",
    "blocked_hours",
    "max_runs_per_hour",
    "failure_streak_threshold",
    "ui_drift_threshold",
    "require_target_confirmation",
    "store_screenshots",
    "store_ax_tree",
    "proposal_mode",
    "auto_apply_level"
  ],
  "properties": {
    "enabled": { "type": "boolean" },
    "dry_run_default": { "type": "boolean" },
    "allowed_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "alias",
          "platform",
          "target_kind",
          "expected_chat_title",
          "expected_participant_labels",
          "allowed_send_modes"
        ],
        "properties": {
          "alias": { "type": "string", "minLength": 3, "maxLength": 64 },
          "platform": { "type": "string", "const": "line_desktop" },
          "target_kind": {
            "type": "string",
            "enum": ["single_user", "group"]
          },
          "expected_chat_title": { "type": "string", "minLength": 1, "maxLength": 128 },
          "expected_window_title_substring": {
            "type": ["string", "null"],
            "maxLength": 128
          },
          "expected_participant_labels": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1, "maxLength": 128 },
            "maxItems": 16
          },
          "expected_ax_fingerprint": {
            "type": ["string", "null"],
            "minLength": 8,
            "maxLength": 128
          },
          "allowed_send_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["dry_run", "execute"]
            },
            "maxItems": 2
          },
          "notes": {
            "type": ["string", "null"],
            "maxLength": 256
          }
        },
        "additionalProperties": false
      }
    },
    "blocked_hours": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timezone", "days", "start_hour", "end_hour"],
        "properties": {
          "timezone": { "type": "string", "minLength": 3, "maxLength": 64 },
          "days": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN"]
            },
            "maxItems": 7
          },
          "start_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
          "end_hour": { "type": "integer", "minimum": 1, "maximum": 24 },
          "label": {
            "type": ["string", "null"],
            "maxLength": 128
          }
        },
        "additionalProperties": false
      }
    },
    "max_runs_per_hour": { "type": "integer", "minimum": 1, "maximum": 60 },
    "failure_streak_threshold": { "type": "integer", "minimum": 1, "maximum": 20 },
    "ui_drift_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "require_target_confirmation": { "type": "boolean" },
    "store_screenshots": { "type": "boolean" },
    "store_ax_tree": { "type": "boolean" },
    "proposal_mode": {
      "type": "string",
      "enum": ["off", "local_queue", "backlog_candidate"]
    },
    "auto_apply_level": {
      "type": "string",
      "enum": ["none", "docs_only", "patch_draft"]
    }
  },
  "additionalProperties": false
}
