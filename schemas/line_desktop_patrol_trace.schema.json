{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://member.app/schemas/line_desktop_patrol_trace.schema.json",
  "title": "line_desktop_patrol_trace",
  "type": "object",
  "required": [
    "run_id",
    "scenario_id",
    "session_id",
    "started_at",
    "finished_at",
    "git_sha",
    "app_version",
    "target_id",
    "sent_text",
    "visible_before",
    "visible_after",
    "screenshot_before",
    "screenshot_after",
    "ax_tree_before",
    "ax_tree_after",
    "model_config",
    "retrieval_refs",
    "evaluator_scores",
    "failure_reason",
    "proposal_id"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "scenario_id": { "type": "string", "minLength": 3, "maxLength": 128 },
    "session_id": { "type": "string", "minLength": 3, "maxLength": 128 },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 },
    "app_version": { "type": "string", "minLength": 1, "maxLength": 128 },
    "target_id": { "type": "string", "minLength": 3, "maxLength": 128 },
    "sent_text": { "type": ["string", "null"] },
    "visible_before": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "text"],
        "properties": {
          "role": { "type": "string", "minLength": 1, "maxLength": 32 },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "visible_after": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "text"],
        "properties": {
          "role": { "type": "string", "minLength": 1, "maxLength": 32 },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "screenshot_before": { "type": ["string", "null"] },
    "screenshot_after": { "type": ["string", "null"] },
    "ax_tree_before": { "type": ["string", "null"] },
    "ax_tree_after": { "type": ["string", "null"] },
    "model_config": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "retrieval_refs": {
      "type": "array",
      "items": {
        "type": ["string", "object"]
      }
    },
    "evaluator_scores": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "failure_reason": { "type": ["string", "null"], "maxLength": 128 },
    "proposal_id": { "type": ["string", "null"], "maxLength": 128 }
  },
  "additionalProperties": true
}
