{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://member.example/schemas/llm_quality_framework.schema.json",
  "title": "Member LLM Quality Framework v1",
  "type": "object",
  "required": [
    "version",
    "dimensions",
    "weights",
    "slices",
    "hardGates",
    "judgeReliabilityPolicy",
    "benchmarkPolicy"
  ],
  "properties": {
    "version": { "type": "string", "pattern": "^v[0-9]+$" },
    "dimensions": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": ["key", "label", "hardGate", "weight"],
        "properties": {
          "key": { "type": "string", "minLength": 2 },
          "label": { "type": "string", "minLength": 2 },
          "hardGate": { "type": "boolean" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "weights": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "slices": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["sliceKey", "critical"],
        "properties": {
          "sliceKey": { "type": "string", "minLength": 2 },
          "critical": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "hardGates": {
      "type": "object",
      "required": ["blockOnAnySliceFail", "blockOnCriticalSliceRegression", "blockOnSafetyRegression"],
      "properties": {
        "blockOnAnySliceFail": { "type": "boolean" },
        "blockOnCriticalSliceRegression": { "type": "boolean" },
        "blockOnSafetyRegression": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "judgeReliabilityPolicy": {
      "type": "object",
      "required": ["maxDisagreementRate", "maxSensitivityDrift", "humanReviewRequiredNearHardGate"],
      "properties": {
        "maxDisagreementRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxSensitivityDrift": { "type": "number", "minimum": 0, "maximum": 1 },
        "humanReviewRequiredNearHardGate": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "benchmarkPolicy": {
      "type": "object",
      "required": ["frozenRequired", "reviewerApprovalRequired", "excludeHighContaminationFromHardGate"],
      "properties": {
        "frozenRequired": { "type": "boolean" },
        "reviewerApprovalRequired": { "type": "boolean" },
        "excludeHighContaminationFromHardGate": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
